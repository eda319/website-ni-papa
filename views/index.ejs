<!-- ================= HOME ================= -->

<section id="home">
  <div class="hero-container">
    <h1 class="hero-title">Elexcellence</h1>

    <p class="hero-tagline">
      Reliable Electrical Solutions for Residential and Small Commercial
      Projects
    </p>

    <p class="hero-description">
      Elexcellence is focused on delivering safe, efficient, and high-quality
      electrical installations and upgrades. We specialize in wiring systems,
      lighting design, and panel improvements built with precision and safety
      standards.
    </p>

    <div class="hero-meta">
      <p>⚡ Electrical Installation & Maintenance</p>
      <p>📍 Based in Quezon City, Philippines</p>
      <p>🔧 Residential • Small Commercial • Repairs</p>
    </div>

    <!-- SERVICES -->

    <div class="home-subsection">
      <h2>Services</h2>

      <div class="services-grid">
        <div class="service-card">
          <h3>Electrical Installation</h3>
          <p>Safe wiring solutions for homes and small businesses.</p>
        </div>

        <div class="service-card">
          <h3>Lighting Systems</h3>
          <p>Indoor and outdoor lighting design and installation.</p>
        </div>

        <div class="service-card">
          <h3>Repairs & Maintenance</h3>
          <p>Troubleshooting and reliable electrical fixes.</p>
        </div>

        <div class="service-card">
          <h3>Panel Upgrades</h3>
          <p>Electrical panel improvements and modernization.</p>
        </div>
      </div>
    </div>

    <!-- WHY US -->

    <div class="home-subsection">
      <h2>Why Choose Us</h2>

      <div class="trust-grid">
        <div class="trust-card">
          <h3>Experience</h3>
          <p>Hands-on electrical work with real project experience.</p>
        </div>

        <div class="trust-card">
          <h3>Reliable Work</h3>
          <p>Safe, efficient, and long-lasting solutions.</p>
        </div>

        <div class="trust-card">
          <h3>Professional Service</h3>
          <p>Clear communication and quality workmanship.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ================= PROJECTS ================= -->

<section id="projects">
  <div class="section-container projects-container">
    <h1 class="section-title">Projects</h1>

    <% ["current","past"].forEach(type=>{ %>

    <div class="project-group">
      <div class="group-header">
        <h2>
          <%= type==="current"
          ? "Current Projects"
          : "Past Projects" %>
        </h2>
      </div>

      <div class="project-slider">
        <% categories[type].forEach(project=>{ %>

        <div class="project-card">
          <h2 class="project-title"><%= project.name %></h2>

          <p class="project-meta">
            <% if(project.location){ %> 📍 <%= project.location %>

            <br />

            <% } %>

            <% if(project.client){ %>

            👤 Client:

            <%= project.client %>

            <% } %>
          </p>

          <p class="project-description"><%= project.description || "" %></p>

          <div class="carousel" data-carousel>
            <button class="carousel-btn prev" onclick="moveSlide(this, -1)">
              <span class="arrow left"></span>
            </button>

            <div class="carousel-track">
              <% project.images.forEach((img,index)=>{ %>

              <div class="slide <%= index===0 ? 'active':'' %>">
                <img
                  src="<%= img.src %>"
                  alt="<%= img.caption %>"
                  loading="<%= index===0 ? 'eager':'lazy' %>"
                  fetchpriority="<%= index===0 ? 'high':'low' %>"
                  class="project-image"
                />

                <% if(img.caption){ %>

                <p class="image-caption"><%= img.caption %></p>

                <% } %>
              </div>

              <% }) %>
            </div>

            <button class="carousel-btn next" onclick="moveSlide(this, 1)">
              <span class="arrow right"></span>
            </button>
          </div>
        </div>

        <% }) %>
      </div>
    </div>

    <% }) %>
  </div>
</section>

<!-- ================= ABOUT ================= -->

<section id="about">
  <div class="section-container">
    <h1>About</h1>

    <p>
      Elexcellence began as a small independent electrical service initiative in
      2024, initially handling residential wiring and repair work.
    </p>

    <!-- EXPERIENCE -->

    <div class="home-subsection">
      <h2>Experience</h2>

      <p>
        Hands-on electrical work combined with continuous learning in modern
        systems.
      </p>

      <ul
        style="
          text-align: left;
          max-width: 700px;
          margin: auto;
          color: #555;
          line-height: 1.8;
        "
      >
        <li>Residential wiring and installations</li>

        <li>Lighting system design and troubleshooting</li>

        <li>Electrical repairs and maintenance</li>

        <li>Field-based project experience</li>
      </ul>
    </div>

    <!-- CERTIFICATIONS -->

    <div class="home-subsection">
      <h2>Certifications</h2>

      <div class="carousel cert-carousel" data-carousel>
        <button class="carousel-btn prev" onclick="moveSlide(this, -1)">
          <span class="arrow left"></span>
        </button>

        <div class="carousel-track">
          <% certifications.forEach((cert,index)=>{ %>

          <div class="slide <%= index===0 ? 'active':'' %>">
            <img
              src="<%= cert.src %>"
              alt="Certification <%= index+1 %>"
              loading="<%= index===0 ? 'eager':'lazy' %>"
              class="certificate-image"
            />
          </div>

          <% }) %>
        </div>

        <button class="carousel-btn next" onclick="moveSlide(this, 1)">
          <span class="arrow right"></span>
        </button>
      </div>
    </div>

    <!-- BUSINESS PERMIT -->

    <div class="home-subsection">
      <h2>Business Permit</h2>

      <p>Registered and authorized electrical service provider.</p>

      <div class="permit-container">
        <img src="/images/permit/permit.webp" alt="Business Permit" />
      </div>
    </div>
  </div>
</section>

